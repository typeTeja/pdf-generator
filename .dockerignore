# Ignore local virtual environment
venv/
.venv/
env/

# Ignore Python cache files
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Ignore local generated PDFs
app/generated/*.pdf

# Ignore version control and IDE settings
.git/
.gitignore
.github/
.idea/
.vscode/
.DS_Store

# Ignore Nixpacks configuration (being replaced)
nixpacks.toml

# Ignore deployment log files or other text logs
*.log
deployment-*.txt
after-deploy.md
plan.md
